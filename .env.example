# ══════════════════════════════════════════════════════════════════════════════
# Closi AI — Variáveis de Ambiente
# Copie para .env e preencha os valores.
# ══════════════════════════════════════════════════════════════════════════════

# ── Claude / LLM ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=4000

# ── Servidor ──────────────────────────────────────────────────────────────────
DEBUG=false
PORT=5000
HOST=0.0.0.0

# ── Autenticação & Segurança ─────────────────────────────────────────────────
# Bearer token para /chat (se vazio, auth desabilitada)
API_SECRET_TOKEN=
# Segundos de debounce para acumular mensagens rápidas
RESPONSE_DELAY_SECONDS=10
# Mensagem enviada ao lead quando o sistema falha
FALLBACK_MESSAGE=Estou com uma instabilidade agora, em breve um consultor vai te atender.
# Máximo de requests/min no /webhook/form por IP
FORM_RATE_LIMIT=5

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJhbGci...

# ── Z-API (WhatsApp) ─────────────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── HubSpot (opcional — desabilitado por padrão) ─────────────────────────────
HUBSPOT_ENABLED=false
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxx
HUBSPOT_PIPELINE_ID=default

# ── Escalação ────────────────────────────────────────────────────────────────
# Telefone do supervisor (com DDI, ex: 5531999999999)
SUPERVISOR_PHONE=
# Botmaker (futuro — transferência direta)
BOTMAKER_API_KEY=
BOTMAKER_TEAM_ID=
