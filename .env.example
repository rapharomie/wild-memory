# ── LLM / embedding providers (default backends) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Storage backend (override the YAML's `store:` section) ──────────────────
# If DATABASE_URL is set, the store kind defaults to postgres.
# DATABASE_URL=postgres://user:pw@host:5432/wild_memory

# Or pin the SQLite file path explicitly:
# WILD_MEMORY_DB_PATH=./wild_memory.db
# WILD_MEMORY_STORE_KIND=sqlite
