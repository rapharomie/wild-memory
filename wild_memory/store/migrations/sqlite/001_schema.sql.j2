-- Wild Memory — SQLite schema (rendered with embedding_dim={{ embedding_dim }})
-- Embeddings live in vec0 virtual tables; everything else is plain SQLite.

CREATE TABLE IF NOT EXISTS wild_memory_meta (
    key   TEXT PRIMARY KEY,
    value TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS observations (
    id                     TEXT PRIMARY KEY,
    agent_id               TEXT NOT NULL,
    user_id                TEXT NOT NULL,
    content                TEXT NOT NULL,
    obs_type               TEXT NOT NULL,
    entities               TEXT NOT NULL DEFAULT '[]',
    importance             INTEGER NOT NULL DEFAULT 5,
    decay_score            REAL NOT NULL DEFAULT 1.0,
    ttl_days               INTEGER NOT NULL DEFAULT 90,
    emotional_valence      TEXT NOT NULL DEFAULT 'neutral',
    emotional_intensity    INTEGER NOT NULL DEFAULT 0,
    privacy_mode           TEXT NOT NULL DEFAULT 'personal',
    event_time             TEXT,
    source_session         TEXT,
    status                 TEXT NOT NULL DEFAULT 'active',
    created_at             TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),
    last_accessed          TEXT,
    invalidated_at         TEXT,
    invalidated_by         TEXT,
    anonymized_user_hash   TEXT
);

CREATE VIRTUAL TABLE IF NOT EXISTS observations_vec USING vec0(
    id        TEXT PRIMARY KEY,
    embedding float[{{ embedding_dim }}]
);

CREATE TABLE IF NOT EXISTS entity_nodes (
    id            TEXT PRIMARY KEY,
    entity_type   TEXT NOT NULL,
    display_name  TEXT NOT NULL,
    attributes    TEXT NOT NULL DEFAULT '{}',
    created_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now'))
);

CREATE TABLE IF NOT EXISTS entity_edges (
    id                 TEXT PRIMARY KEY,
    subject_id         TEXT NOT NULL,
    predicate          TEXT NOT NULL,
    object_id          TEXT NOT NULL,
    source_observation TEXT,
    properties         TEXT NOT NULL DEFAULT '{}',
    created_at         TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),
    UNIQUE (subject_id, predicate, object_id)
);

CREATE TABLE IF NOT EXISTS reflections (
    id              TEXT PRIMARY KEY,
    agent_id        TEXT NOT NULL,
    user_id         TEXT NOT NULL,
    reflection_type TEXT NOT NULL,
    content         TEXT NOT NULL,
    importance      INTEGER NOT NULL DEFAULT 5,
    created_at      TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now'))
);

CREATE TABLE IF NOT EXISTS feedback_signals (
    id              TEXT PRIMARY KEY,
    agent_id        TEXT NOT NULL,
    user_id         TEXT NOT NULL,
    session_id      TEXT NOT NULL,
    signal_type     TEXT NOT NULL,
    reward_score    REAL NOT NULL DEFAULT 0,
    action_taken    TEXT,
    procedure_id    TEXT,
    procedure_step  TEXT,
    source          TEXT NOT NULL DEFAULT 'implicit',
    external_ref    TEXT,
    created_at      TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now'))
);

CREATE TABLE IF NOT EXISTS procedures (
    id                     TEXT PRIMARY KEY,
    agent_id               TEXT NOT NULL,
    name                   TEXT NOT NULL,
    status                 TEXT NOT NULL DEFAULT 'active',
    steps                  TEXT NOT NULL DEFAULT '[]',
    trigger_entities       TEXT NOT NULL DEFAULT '[]',
    total_executions       INTEGER NOT NULL DEFAULT 0,
    successful_executions  INTEGER NOT NULL DEFAULT 0,
    performance_score      REAL NOT NULL DEFAULT 0,
    updated_at             TEXT,
    created_at             TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now'))
);

CREATE TABLE IF NOT EXISTS citation_trails (
    id                     TEXT PRIMARY KEY,
    agent_id               TEXT NOT NULL,
    user_id                TEXT NOT NULL,
    session_id             TEXT NOT NULL,
    message_index          INTEGER NOT NULL,
    used_observation_ids   TEXT NOT NULL DEFAULT '[]',
    used_reflection_ids    TEXT NOT NULL DEFAULT '[]',
    active_procedure_id    TEXT,
    active_procedure_step  TEXT,
    n_sources              INTEGER NOT NULL DEFAULT 0,
    avg_decay_score        REAL,
    created_at             TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now'))
);

CREATE TABLE IF NOT EXISTS session_logs (
    id          TEXT PRIMARY KEY,
    session_id  TEXT NOT NULL UNIQUE,
    agent_id    TEXT NOT NULL DEFAULT '',
    user_id     TEXT NOT NULL DEFAULT '',
    messages    TEXT NOT NULL DEFAULT '[]',
    expires_at  TEXT,
    created_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now'))
);

CREATE TABLE IF NOT EXISTS semantic_cache (
    id            TEXT PRIMARY KEY,
    agent_id      TEXT NOT NULL,
    query_text    TEXT NOT NULL,
    response_text TEXT NOT NULL,
    hit_count     INTEGER NOT NULL DEFAULT 0,
    last_hit      TEXT,
    ttl_hours     INTEGER NOT NULL DEFAULT 72,
    expires_at    TEXT,
    created_at    TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now'))
);

CREATE VIRTUAL TABLE IF NOT EXISTS semantic_cache_vec USING vec0(
    id        TEXT PRIMARY KEY,
    embedding float[{{ embedding_dim }}]
);

CREATE TABLE IF NOT EXISTS agent_checkpoints (
    id                 TEXT PRIMARY KEY,
    agent_id           TEXT NOT NULL,
    session_id         TEXT NOT NULL,
    working_memory     TEXT NOT NULL DEFAULT '{}',
    active_procedure   TEXT,
    last_used_obs_ids  TEXT NOT NULL DEFAULT '[]',
    message_count      INTEGER NOT NULL DEFAULT 0,
    created_at         TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),
    UNIQUE (agent_id, session_id)
);

CREATE TABLE IF NOT EXISTS agent_imprints (
    agent_id       TEXT PRIMARY KEY,
    role           TEXT,
    "values"       TEXT NOT NULL DEFAULT '[]',
    constraints    TEXT NOT NULL DEFAULT '[]',
    org_context    TEXT NOT NULL DEFAULT '{}',
    tone_of_voice  TEXT,
    created_at     TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),
    updated_at     TEXT
);
