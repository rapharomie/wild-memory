-- Wild Memory — Postgres schema (rendered with embedding_dim={{ embedding_dim }})

CREATE TABLE IF NOT EXISTS wild_memory_meta (
    key   TEXT PRIMARY KEY,
    value TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS observations (
    id                     UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    agent_id               TEXT NOT NULL,
    user_id                TEXT NOT NULL,
    content                TEXT NOT NULL,
    obs_type               TEXT NOT NULL,
    entities               TEXT[] NOT NULL DEFAULT '{}',
    importance             INTEGER NOT NULL DEFAULT 5,
    decay_score            DOUBLE PRECISION NOT NULL DEFAULT 1.0,
    ttl_days               INTEGER NOT NULL DEFAULT 90,
    emotional_valence      TEXT NOT NULL DEFAULT 'neutral',
    emotional_intensity    INTEGER NOT NULL DEFAULT 0,
    privacy_mode           TEXT NOT NULL DEFAULT 'personal',
    event_time             TIMESTAMPTZ,
    source_session         TEXT,
    embedding              vector({{ embedding_dim }}),
    status                 TEXT NOT NULL DEFAULT 'active',
    created_at             TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    last_accessed          TIMESTAMPTZ,
    invalidated_at         TIMESTAMPTZ,
    invalidated_by         UUID,
    anonymized_user_hash   TEXT
);

CREATE INDEX IF NOT EXISTS idx_obs_agent_user_status
    ON observations (agent_id, user_id, status);
CREATE INDEX IF NOT EXISTS idx_obs_decay_status
    ON observations (status, decay_score);
CREATE INDEX IF NOT EXISTS idx_obs_obs_type
    ON observations (obs_type);
CREATE INDEX IF NOT EXISTS idx_obs_embedding_hnsw
    ON observations USING hnsw (embedding vector_cosine_ops);

CREATE TABLE IF NOT EXISTS entity_nodes (
    id            TEXT PRIMARY KEY,
    entity_type   TEXT NOT NULL,
    display_name  TEXT NOT NULL,
    attributes    JSONB NOT NULL DEFAULT '{}'::jsonb,
    created_at    TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS entity_edges (
    id                 UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    subject_id         TEXT NOT NULL,
    predicate          TEXT NOT NULL,
    object_id          TEXT NOT NULL,
    source_observation UUID,
    properties         JSONB NOT NULL DEFAULT '{}'::jsonb,
    created_at         TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    UNIQUE (subject_id, predicate, object_id)
);

CREATE TABLE IF NOT EXISTS reflections (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    agent_id        TEXT NOT NULL,
    user_id         TEXT NOT NULL,
    reflection_type TEXT NOT NULL,
    content         TEXT NOT NULL,
    importance      INTEGER NOT NULL DEFAULT 5,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()
);
CREATE INDEX IF NOT EXISTS idx_refl_agent_user ON reflections (agent_id, user_id);

CREATE TABLE IF NOT EXISTS feedback_signals (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    agent_id        TEXT NOT NULL,
    user_id         TEXT NOT NULL,
    session_id      TEXT NOT NULL,
    signal_type     TEXT NOT NULL,
    reward_score    DOUBLE PRECISION NOT NULL DEFAULT 0,
    action_taken    TEXT,
    procedure_id    UUID,
    procedure_step  TEXT,
    source          TEXT NOT NULL DEFAULT 'implicit',
    external_ref    TEXT,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()
);
CREATE INDEX IF NOT EXISTS idx_feedback_session ON feedback_signals (session_id);
CREATE INDEX IF NOT EXISTS idx_feedback_agent_user ON feedback_signals (agent_id, user_id);

CREATE TABLE IF NOT EXISTS procedures (
    id                     UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    agent_id               TEXT NOT NULL,
    name                   TEXT NOT NULL,
    status                 TEXT NOT NULL DEFAULT 'active',
    steps                  JSONB NOT NULL DEFAULT '[]'::jsonb,
    trigger_entities       TEXT[] NOT NULL DEFAULT '{}',
    total_executions       INTEGER NOT NULL DEFAULT 0,
    successful_executions  INTEGER NOT NULL DEFAULT 0,
    performance_score      DOUBLE PRECISION NOT NULL DEFAULT 0,
    updated_at             TIMESTAMPTZ,
    created_at             TIMESTAMPTZ NOT NULL DEFAULT NOW()
);
CREATE INDEX IF NOT EXISTS idx_proc_agent_status ON procedures (agent_id, status);

CREATE TABLE IF NOT EXISTS citation_trails (
    id                     UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    agent_id               TEXT NOT NULL,
    user_id                TEXT NOT NULL,
    session_id             TEXT NOT NULL,
    message_index          INTEGER NOT NULL,
    used_observation_ids   UUID[] NOT NULL DEFAULT '{}',
    used_reflection_ids    UUID[] NOT NULL DEFAULT '{}',
    active_procedure_id    UUID,
    active_procedure_step  TEXT,
    n_sources              INTEGER NOT NULL DEFAULT 0,
    avg_decay_score        DOUBLE PRECISION,
    created_at             TIMESTAMPTZ NOT NULL DEFAULT NOW()
);
CREATE INDEX IF NOT EXISTS idx_citation_session ON citation_trails (session_id);

CREATE TABLE IF NOT EXISTS session_logs (
    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    session_id  TEXT NOT NULL UNIQUE,
    agent_id    TEXT NOT NULL DEFAULT '',
    user_id     TEXT NOT NULL DEFAULT '',
    messages    JSONB NOT NULL DEFAULT '[]'::jsonb,
    expires_at  TIMESTAMPTZ,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW()
);
CREATE INDEX IF NOT EXISTS idx_session_expires ON session_logs (expires_at);

CREATE TABLE IF NOT EXISTS semantic_cache (
    id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    agent_id      TEXT NOT NULL,
    query_text    TEXT NOT NULL,
    response_text TEXT NOT NULL,
    embedding     vector({{ embedding_dim }}),
    hit_count     INTEGER NOT NULL DEFAULT 0,
    last_hit      TIMESTAMPTZ,
    ttl_hours     INTEGER NOT NULL DEFAULT 72,
    expires_at    TIMESTAMPTZ,
    created_at    TIMESTAMPTZ NOT NULL DEFAULT NOW()
);
CREATE INDEX IF NOT EXISTS idx_cache_agent ON semantic_cache (agent_id);
CREATE INDEX IF NOT EXISTS idx_cache_expires ON semantic_cache (expires_at);
CREATE INDEX IF NOT EXISTS idx_cache_embedding_hnsw
    ON semantic_cache USING hnsw (embedding vector_cosine_ops);

CREATE TABLE IF NOT EXISTS agent_checkpoints (
    id                 UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    agent_id           TEXT NOT NULL,
    session_id         TEXT NOT NULL,
    working_memory     JSONB NOT NULL DEFAULT '{}'::jsonb,
    active_procedure   JSONB,
    last_used_obs_ids  UUID[] NOT NULL DEFAULT '{}',
    message_count      INTEGER NOT NULL DEFAULT 0,
    created_at         TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    UNIQUE (agent_id, session_id)
);

CREATE TABLE IF NOT EXISTS agent_imprints (
    agent_id       TEXT PRIMARY KEY,
    role           TEXT,
    "values"       JSONB NOT NULL DEFAULT '[]'::jsonb,
    constraints    JSONB NOT NULL DEFAULT '[]'::jsonb,
    org_context    JSONB NOT NULL DEFAULT '{}'::jsonb,
    tone_of_voice  TEXT,
    created_at     TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at     TIMESTAMPTZ
);
