# ─────────────────────────────────────────────────────────────────────────────
# Wild Memory — configuration
# Generated by `wild-memory init`. Edit freely.
# ─────────────────────────────────────────────────────────────────────────────

# ── Storage backend ─────────────────────────────────────────────────────────
# Two backends ship with Wild Memory:
#   sqlite   — local file via sqlite-vec. Zero external services.
#   postgres — Postgres + pgvector via asyncpg.
#
# Override via env: DATABASE_URL (auto-selects postgres),
#                   WILD_MEMORY_DB_PATH, WILD_MEMORY_STORE_KIND.
store:
  kind: "{{ store_kind|default('sqlite') }}"
  path: "{{ store_path|default('./wild_memory.db') }}"
  dsn: "{{ store_dsn|default('') }}"

# ── LLM models ──────────────────────────────────────────────────────────────
# `premium` is used for user-facing replies.
# `economy` is used for internal operations (distillation, conflict checks,
# reflection, goal detection). Roughly 70% cheaper.
models:
  premium:
    provider: anthropic
    model: claude-sonnet-4-5-20250929
    cost_per_1m_input: 3.0
    cost_per_1m_output: 15.0
  economy:
    provider: anthropic
    model: claude-haiku-4-5-20251001
    cost_per_1m_input: 0.80
    cost_per_1m_output: 4.0

# ── Embeddings ──────────────────────────────────────────────────────────────
# Dimensions must match the value the schema was migrated with. Changing
# the model usually means re-running `wild-memory migrate` against a fresh
# database (mismatched dim is a fail-fast on connect).
embedding:
  provider: openai
  model: text-embedding-3-small
  dimensions: {{ embedding_dim|default(1536) }}

# ── Agent identity (Salmon) ─────────────────────────────────────────────────
imprint_path: memory/imprint.yaml
procedures_dir: memory/procedures
memory_dir: memory

# ── Decay / forgetting (Ant) ────────────────────────────────────────────────
# Memories not accessed lose strength every day. Protected types are
# exempt from automatic archive.
decay:
  daily_rate: 0.02            # 2% per day on all active observations
  stale_threshold: 0.3        # below this → marked stale
  archive_threshold: 0.1      # below this → archived (excluding protected)
  protected_types:
    - decision
    - correction
  protected_min_importance: 7

# ── TTL by observation type (days) ──────────────────────────────────────────
ttl_defaults:
  decision: 180
  preference: 90
  fact: 365
  goal: 30
  correction: 365
  feedback: 60
  insight: 180

# ── Semantic cache (Elephant) ───────────────────────────────────────────────
# Cache responses for semantically similar queries. Personal queries (with
# any of the configured keywords) bypass the cache to avoid leakage.
cache:
  enabled: true
  similarity_threshold: 0.93
  ttl_hours: 72
  personal_keywords: []        # add keywords in your language to bypass cache

# ── Retrieval signal weights (Elephant) ─────────────────────────────────────
# Weights for the 5-signal combined retrieval score. Should sum to ~1.0.
retrieval_weights:
  semantic: 0.30
  entity_match: 0.20
  fts_keyword: 0.15
  recency: 0.15
  decay: 0.12
  emotion: 0.08

# ── Distillation gate (Bee) ─────────────────────────────────────────────────
# Filters trivial messages BEFORE spending tokens on distillation.
# Defaults are intentionally empty — fill in for your language and domain.
gate:
  min_chars: 40
  trivial_patterns: []         # regexes that mark a message as trivial
  signal_keywords: []          # words that always pass the gate

# ── Caches & checkpoints ────────────────────────────────────────────────────
briefing_cache:
  max_turns_without_rebuild: 4

goal_cache:
  max_turns: 4
  change_signals: []

checkpoint:
  interval_messages: 5

session_log:
  ttl_days: 14

conflict:
  similarity_threshold: 0.85

# ── Context window ──────────────────────────────────────────────────────────
max_context_tokens: 150000
compress_threshold: 0.7
